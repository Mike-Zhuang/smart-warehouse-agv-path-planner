[Unit]
Description=Smart Warehouse AGV Path Planner API
After=network.target

[Service]
Type=simple
User=www
Group=www
WorkingDirectory=/opt/smart-warehouse-agv-path-planner
ExecStart=/opt/smart-warehouse-agv-path-planner/.venv/bin/python -m uvicorn backend.app:app --host 127.0.0.1 --port 18080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
